# ==============================================================================
# LiveKit & Egress Production Environment Configuration
# ==============================================================================
# Copy this file to '.env' and modify the values for your environment.
# Note: Dokploy allows setting these variables in the application dashboard.

# ------------------------------------------------------------------------------
# 1. LiveKit Core Server Configuration
# ------------------------------------------------------------------------------

# Timezone for container logs and internal scheduler
TZ=UTC

# The primary HTTP/WebSocket signaling port.
# Dokploy will route your external domain (e.g. livekit.example.com) to this port.
LIVEKIT_PORT=7880

# Public domain routed by Dokploy/Traefik to the livekit-server service.
LIVEKIT_DOMAIN=livekit.example.com

# Browser origins allowed to call LiveKit HTTP/WebSocket validation endpoints.
# For your current project, set your real frontend origin in .env or Dokploy.
LIVEKIT_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Logging level for LiveKit Server (debug, info, warn, error)
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# 2. Security & Credentials
# ------------------------------------------------------------------------------

# LiveKit API Key and Secret. These are used by your backend applications 
# to generate JWT tokens for room participants.
# Generate strong, random alphanumeric keys (e.g., openssl rand -hex 16/32).
LIVEKIT_API_KEY=replace_with_random_api_key
LIVEKIT_API_SECRET=replace_with_random_api_secret_at_least_32_chars

# ------------------------------------------------------------------------------
# 3. Redis State Store (Mandatory for Egress & Clustering)
# ------------------------------------------------------------------------------
# Choose one of the options below:
#
# Option A: Deploy Redis inside this Compose stack (Local)
# Set REDIS_URL to point to the 'redis' container service.
# REDIS_URL=redis://redis:6379/0
#
# Option B: Use an external Redis server (e.g., managed by Dokploy or external)
# REDIS_URL=redis://[:password]@external-redis-host:6379/0
# If your password has special characters, ensure they are URL-encoded.
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 4. WebRTC & Firewall Configuration (RTC)
# ------------------------------------------------------------------------------

# Set to 'true' in production to allow LiveKit to auto-discover the host's 
# public IP address using STUN servers. Essential for NAT traversal.
RTC_USE_EXTERNAL_IP=true

# ICE over TCP port. Helpful for users behind restrictive firewalls.
RTC_TCP_PORT=7881

# Single-port UDP Mux configuration (Recommended).
# All WebRTC media (audio/video) streams will be multiplexed over this single port.
# You MUST open this port (7882/UDP) in your VPS firewall.
RTC_UDP_PORT=7882

# ------------------------------------------------------------------------------
# 5. TURN Server (Firewall Traversal)
# ------------------------------------------------------------------------------

# Enable/disable the built-in TURN server
TURN_ENABLED=true

# The public domain pointing to your LiveKit server (e.g. turn.example.com).
# Clients behind corporate firewalls use this domain to route TURN traffic.
TURN_DOMAIN=turn.example.com

# Plain UDP TURN port. Used for non-TLS media relay.
# You MUST open this port (3478/UDP) in your VPS firewall.
TURN_UDP_PORT=3478

# TLS TURN port. Used to bypass strict proxies blocking standard ports.
# You MUST open this port (5349/TCP) in your VPS firewall.
TURN_TLS_PORT=5349

# TURN TLS Certificates (Optional)
# If you mount your Let's Encrypt SSL certificates into the container,
# specify the file paths below. Leave empty if you do not have certificates
# available for TURN TLS or want to run plain UDP/TCP TURN on 3478.
TURN_CERT_FILE=
TURN_KEY_FILE=

# ------------------------------------------------------------------------------
# 6. Egress (Recording & Streaming) Integration
# ------------------------------------------------------------------------------

# The WebSocket URL Egress uses to connect to the LiveKit server.
# Using the docker-compose internal service name is recommended.
LIVEKIT_WS_URL=ws://livekit-server:7880

# ------------------------------------------------------------------------------
# 7. MinIO / S3-Compatible Storage Configuration
# ------------------------------------------------------------------------------
# Prepare Egress to upload recordings to your MinIO instance.
# Credentials are read at runtime by the Egress service during upload requests.

# Endpoint for your MinIO server (include http:// or https://)
# Use internal DNS name if MinIO is in the same docker network (e.g. http://minio:9000)
# or the public domain (e.g. https://minio.yourdomain.com).
EGRESS_MINIO_ENDPOINT=http://minio:9000

# MinIO Root Username (Access Key)
EGRESS_MINIO_ACCESS_KEY=replace_with_minio_access_key

# MinIO Root Password (Secret Key)
EGRESS_MINIO_SECRET_KEY=replace_with_minio_secret_key

# Target bucket for LiveKit recordings (ensure this bucket exists in MinIO)
EGRESS_MINIO_BUCKET=livekit-recordings

# Force path style URLs (Required for MinIO and other S3-compatible providers)
EGRESS_MINIO_FORCE_PATH_STYLE=true
